    "def cost_of_project(engraving, solid_gold):\n",
    "    cost = 0\n",
    "    gold_plated = 50\n",
    "    solid = 100\n",
    "    if solid_gold:\n",
    "        cost += solid + 10*len(engraving)\n",
    "    else:\n",
    "        cost += gold_plated + 7*len(engraving)\n",
    "    return cost\n",
    "\n",
